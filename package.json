{
  "private": true,
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "dev": "cd demo && bun run dev",
    "build:demo": "cd demo && bun run build",
    "build:lib": "cd packages/viewer && bun run build",
    "typecheck": "cd packages/viewer && bun run typecheck",
    "setup": "cd packages/tools && bun run scripts/setup-from-client.ts",
    "extract": "cd packages/tools && bun run scripts/build-assets.ts",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",

    "test:scan": "cd demo/test && bun run scripts/scan.ts",
    "test:review": "cd demo/test && bun run scripts/review.ts",
    "test:approve": "cd demo/test && bun run scripts/approve.ts",
    "test:status": "cd demo/test && bun run scripts/status.ts",
    "test:install": "cd demo/test && bun install && npx playwright install chromium",
    "test:setup": "./setup.sh"
  }
}
